{
  "name": "@atlex/mail",
  "version": "0.1.3",
  "description": "Mailables and mail transports for Atlex",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Karen Hamazaspyan",
    "url": "https://github.com/khamazaspyan"
  },
  "keywords": [
    "atlex",
    "mail",
    "email",
    "mailer",
    "email-sender",
    "smtp",
    "mailgun",
    "ses",
    "amazon-ses",
    "email-templates",
    "email-builder",
    "fluent-mail",
    "transactional-email",
    "html-email",
    "nodemailer-alternative",
    "nodemailer",
    "laravel-mail",
    "laravel-mailables",
    "laravel-alternative",
    "nodejs",
    "javascript",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atlex-framework/mail.git",
    "directory": "packages/mail"
  },
  "homepage": "https://atlex.dev",
  "bugs": {
    "url": "https://github.com/atlex-framework/mail/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run -c vitest.config.ts",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/MailFake.d.ts",
      "import": "./dist/testing/MailFake.js",
      "require": "./dist/testing/MailFake.js",
      "default": "./dist/testing/MailFake.js"
    }
  },
  "peerDependencies": {
    "@atlex/core": "workspace:*",
    "@atlex/queue": "workspace:*"
  },
  "dependencies": {
    "@atlex/core": "workspace:*",
    "@atlex/queue": "workspace:*",
    "@aws-sdk/client-ses": "^3.0.0",
    "marked": "^16.1.1",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.0",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
